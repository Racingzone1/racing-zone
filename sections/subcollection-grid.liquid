{%- style -%}
  .subcoll-wrapper {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .subcoll-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }
  .subcoll-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 1.5rem;
  }
  .subcoll-card {
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    display: block;
    background: rgb(var(--color-background));
  }
  .subcoll-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    transform: translateY(-2px);
  }
  .subcoll-card__media {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .subcoll-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .subcoll-card:hover .subcoll-card__media img {
    transform: scale(1.05);
  }
  .subcoll-card__media svg {
    width: 60px;
    height: 60px;
    opacity: 0.2;
  }
  .subcoll-card__body {
    padding: 0.85rem 1rem;
  }
  .subcoll-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
    line-height: 1.3;
  }
  .subcoll-card__count {
    font-size: 0.8rem;
    opacity: 0.6;
    margin: 0;
  }
  @media screen and (max-width: 749px) {
    .subcoll-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile | plus: 0 }}, 1fr);
      gap: 1rem;
    }
    .subcoll-title { font-size: 1.5rem; }
  }
{%- endstyle -%}

<div class="subcoll-wrapper page-width">
  {%- unless collection.title == blank -%}
    <h1 class="subcoll-title">{{ collection.title }}</h1>
  {%- endunless -%}

  {%- liquid
    assign current_handle = collection.handle
    assign collection_path = '/collections/' | append: current_handle
    assign child_links = nil
  -%}

  {%- for l1 in linklists['main-menu-1'].links -%}
    {%- for l2 in l1.links -%}
      {%- if child_links == nil and l2.url contains collection_path -%}
        {%- if l2.links.size > 0 -%}
          {%- assign child_links = l2.links -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endfor -%}

  {%- if child_links == nil -%}
    {%- for l1 in linklists['main-menu-1'].links -%}
      {%- if child_links == nil and l1.url contains collection_path -%}
        {%- if l1.links.size > 0 -%}
          {%- assign child_links = l1.links -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- if child_links != nil and child_links.size > 0 -%}
    <div class="subcoll-grid">
      {%- for link in child_links -%}
        {%- assign sub_handle = link.url | split: '/collections/' | last | split: '?' | first -%}
        {%- assign sub_coll = collections[sub_handle] -%}
        {%- assign sub_count = sub_coll.products_count | plus: 0 -%}
        {%- if sub_coll != nil -%}
        {%- assign sub_img = sub_coll.image -%}
        {%- if sub_img == blank -%}
          {%- assign sub_img = sub_coll.products.first.featured_image -%}
        {%- endif -%}
        <a href="{{ link.url }}" class="subcoll-card">
          <div class="subcoll-card__media">
            {%- if sub_img != blank -%}
              <img src="{{ sub_img | image_url: width: 400 }}"
                   alt="{{ link.title }}"
                   loading="lazy"
                   width="400" height="400">
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"/>
              </svg>
            {%- endif -%}
          </div>
          <div class="subcoll-card__body">
            <p class="subcoll-card__title">{{ link.title }}</p>
            {%- if sub_coll != nil -%}
              <p class="subcoll-card__count">{{ sub_coll.products_count }} {{ sub_coll.products_count | pluralize: 'produs', 'produse' }}</p>
            {%- endif -%}
          </div>
        </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p>Nu există subcategorii definite în meniu pentru această colecție.</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Subcollection Grid",
  "settings": [
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        {"value": "2", "label": "2 coloane"},
        {"value": "3", "label": "3 coloane"},
        {"value": "4", "label": "4 coloane"},
        {"value": "5", "label": "5 coloane"}
      ],
      "default": "5",
      "label": "Coloane desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {"value": "1", "label": "1 coloana"},
        {"value": "2", "label": "2 coloane"}
      ],
      "default": "2",
      "label": "Coloane mobile"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [{ "name": "Subcollection Grid" }]
}
{% endschema %}