{% comment %}
  Displays subcollections for the current collection using the custom.subcollections metafield.
{% endcomment %}

{%- assign subcollections = collection.metafields.custom.subcollections.value -%}

{%- assign sub_size = subcollections | size -%}
{%- if subcollections != blank and sub_size > 0 -%}
  <div class="subcollections-grid page-width" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
    {%- if section.settings.title != blank -%}
      <h2 class="subcollections-grid__heading">{{ section.settings.title }}</h2>
    {%- endif -%}
    <ul class="subcollections-grid__list" role="list">
      {%- for subcollection in subcollections -%}
        {%- assign sub_img = subcollection.featured_image -%}
        {%- unless sub_img -%}
          {%- assign sub_img = subcollection.products.first.featured_image -%}
        {%- endunless -%}
        {%- assign sub_count = subcollection.products_count -%}
        <li class="subcollections-grid__item">
          <a href="{{ subcollection.url }}" class="subcollections-grid__link">
            {%- if sub_img -%}
              <div class="subcollections-grid__image-wrap">
                <img
                  src="{{ sub_img | image_url: width: 400 }}"
                  alt="{{ sub_img.alt | default: subcollection.title | escape }}"
                  width="400"
                  height="400"
                  loading="lazy"
                >
              </div>
            {%- else -%}
              <div class="subcollections-grid__image-wrap subcollections-grid__image-wrap--placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
            <span class="subcollections-grid__title">{{ subcollection.title }}</span>
            <span class="subcollections-grid__count">
              {{ sub_count }}
              {%- if sub_count == 1 %} produs{%- else %} produse{%- endif %}
            </span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>

  <style>
    .subcollections-grid {
      margin: 0 auto;
    }
    .subcollections-grid__heading {
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 2rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .subcollections-grid__list {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 1rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .subcollections-grid__item {
      display: flex;
    }
    .subcollections-grid__link {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      text-decoration: none;
      color: inherit;
      width: 100%;
      border: 1px solid rgba(0,0,0,0.1);
      border-radius: 8px;
      overflow: hidden;
      transition: box-shadow 0.2s ease, transform 0.2s ease;
    }
    .subcollections-grid__link:hover {
      box-shadow: 0 4px 20px rgba(0,0,0,0.12);
      transform: translateY(-2px);
    }
    .subcollections-grid__image-wrap {
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      background: #f5f5f5;
    }
    .subcollections-grid__image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }
    .subcollections-grid__link:hover .subcollections-grid__image-wrap img {
      transform: scale(1.05);
    }
    .subcollections-grid__image-wrap--placeholder svg {
      width: 100%;
      height: 100%;
      padding: 1rem;
      opacity: 0.3;
    }
    .subcollections-grid__title {
      display: block;
      padding: 0.6rem 0.5rem 0.1rem;
      font-weight: 600;
      font-size: 0.8rem;
      line-height: 1.3;
    }
    .subcollections-grid__count {
      display: block;
      padding: 0 0.5rem 0.6rem;
      font-size: 0.72rem;
      color: rgba(0,0,0,0.45);
    }
    @media (max-width: 989px) {
      .subcollections-grid__list {
        grid-template-columns: repeat({{ section.settings.columns_mobile | plus: 0 }}, 1fr);
      }
    }
    @media (max-width: 749px) {
      .subcollections-grid__list {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Subcollections Grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Subcategorii"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 6,
      "label": "Columns (desktop)"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Padding top",
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Padding bottom",
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Subcollections Grid"
    }
  ]
}
{% endschema %}
